{
  "name": "woo-desktop",
  "private": true,
  "version": "0.5.0",
  "type": "module",
  "description": "鏃犳垜绗旇锛堟湰鍦扮増锛?绾湰鍦?SQLite 瀛樺偍锛屾棤闇€浠讳綍鍚庣鏈嶅姟",
  "author": "stophemo",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc && vite build",
    "preview": "vite preview",
    "electron:dev": "cross-env NODE_ENV=development electron .",
    "electron:build": "vue-tsc && vite build && electron-builder",
    "build:icons": "electron scripts/generate-icons.cjs",
    "rebuild:sqlite": "electron-rebuild -f -w better-sqlite3 -w sqlite-vec",
    "postinstall": "electron-builder install-app-deps"
  },
  "build": {
    "appId": "com.nonegonotes.woo.local",
    "productName": "Woo",
    "artifactName": "woo-desktop-${version}-${os}-${arch}.${ext}",
    "asarUnpack": [
      "node_modules/better-sqlite3/**/*",
      "node_modules/sqlite-vec*/**/*"
    ],
    "files": [
      "dist/**/*",
      "electron/**/*",
      "!electron/userData/**"
    ],
    "directories": {
      "buildResources": "build",
      "output": "release"
    },
    "win": {
      "icon": "build/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "artifactName": "woo-desktop-${version}-${os}-${arch}-setup.${ext}",
      "oneClick": false,
      "perMachine": true,
      "allowToChangeInstallationDirectory": true,
      "deleteAppDataOnUninstall": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Woo"
    },
    "portable": {
      "artifactName": "woo-desktop-${version}-${os}-${arch}-portable.${ext}"
    },
    "mac": {
      "icon": "build/icon.png",
      "artifactName": "woo-desktop-${version}-${os}-${arch}.${ext}",
      "hardenedRuntime": false,
      "gatekeeperAssess": false,
      "target": [
        "dmg",
        "zip"
      ]
    },
    "linux": {
      "icon": "build/icon.png",
      "artifactName": "woo-desktop-${version}-${os}-${arch}.${ext}",
      "target": [
        "AppImage",
        "deb"
      ]
    }
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.106.1",
    "@tiptap/extension-highlight": "^3.22.4",
    "@tiptap/extension-placeholder": "^3.22.4",
    "@tiptap/extension-task-item": "^3.22.4",
    "@tiptap/extension-task-list": "^3.22.4",
    "@tiptap/extension-typography": "^3.22.4",
    "@tiptap/extension-underline": "^3.22.4",
    "@tiptap/pm": "^3.22.4",
    "@tiptap/starter-kit": "^3.22.4",
    "@tiptap/vue-3": "^3.22.4",
    "@xenova/transformers": "^2.17.2",
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^11.3.0",
    "d3": "^7.9.0",
    "marked": "^15.0.12",
    "markmap-lib": "^0.18.12",
    "markmap-view": "^0.18.12",
    "pinia": "^3.0.4",
    "sqlite-vec": "^0.1.9",
    "turndown": "^7.2.4",
    "turndown-plugin-gfm": "^1.0.2",
    "vue": "^3.4.21",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.6.0",
    "@types/d3": "^7.4.3",
    "@types/turndown": "^5.0.6",
    "@vitejs/plugin-vue": "^5.0.4",
    "cross-env": "^7.0.3",
    "electron": "^29.4.6",
    "electron-builder": "^24.9.1",
    "typescript": "^5.2.2",
    "vite": "^5.2.0",
    "vite-plugin-electron": "^0.28.0",
    "vue-tsc": "^2.0.6"
  }
}
