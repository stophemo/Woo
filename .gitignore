# ============ App (Frontend) ============
# Dependencies
app/node_modules

# Build output
app/dist
app/dist-electron
app/dist-ssr
app/release

# Electron userData (cache, local storage, etc.)
app/electron/userData

# 图标生成的中间产物（保留 icon.svg / icon.png / icon.ico）
app/build/icon-*.png

# ============ App-Local (Local Frontend) ============
# Dependencies
app-local/node_modules

# Build output
app-local/dist
app-local/dist-electron
app-local/dist-ssr
app-local/release

# Electron userData (cache, local storage, etc.)
app-local/electron/userData

# 图标生成的中间产物（保留 icon.svg / icon.png / icon.ico）
app-local/build/icon-*.png

# Install logs
app-local/install.log

# ============ Services (Backend) ============
# Maven
services/target/
services/**/target/
!services/.mvn/wrapper/maven-wrapper.jar

# IDE
services/.idea/
services/*.iml
services/**/*.iml

# Logs
services/logs/
services/**/*.log

# ============ Common ============
# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Environment variables
.env
.env.local
.env.*.local

# OS files
.DS_Store
Thumbs.db

# Temporary files
*.tmp
*.temp
*.local

# IDE
.trae
.qoder/
