{
  "name": "woo-local",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "无我笔记（本地版）- 纯本地 SQLite 存储，无需任何后端服务",
  "author": "NoneGoNotes",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc && vite build",
    "preview": "vite preview",
    "electron:dev": "cross-env NODE_ENV=development electron .",
    "electron:build": "vue-tsc && vite build && electron-builder",
    "build:icons": "electron scripts/generate-icons.cjs",
    "rebuild:sqlite": "electron-rebuild -f -w better-sqlite3",
    "postinstall": "electron-builder install-app-deps"
  },
  "build": {
    "appId": "com.nonegonotes.woo.local",
    "productName": "无我笔记（本地版）",
    "artifactName": "woo-local-${version}-${os}-${arch}.${ext}",
    "asarUnpack": [
      "node_modules/better-sqlite3/**/*"
    ],
    "files": [
      "dist/**/*",
      "electron/**/*",
      "!electron/userData/**"
    ],
    "directories": {
      "buildResources": "build",
      "output": "release"
    },
    "win": {
      "icon": "build/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        },
        {
          "target": "portable",
          "arch": ["x64"]
        },
        {
          "target": "zip",
          "arch": ["x64"]
        }
      ]
    },
    "nsis": {
      "artifactName": "woo-local-${version}-${os}-${arch}-setup.${ext}",
      "oneClick": false,
      "perMachine": true,
      "allowToChangeInstallationDirectory": true,
      "deleteAppDataOnUninstall": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "无我笔记（本地版）"
    },
    "portable": {
      "artifactName": "woo-local-${version}-${os}-${arch}-portable.${ext}"
    },
    "mac": {
      "icon": "build/icon.png",
      "artifactName": "woo-local-${version}-${os}-${arch}.${ext}",
      "target": ["dmg", "zip"]
    },
    "linux": {
      "icon": "build/icon.png",
      "artifactName": "woo-local-${version}-${os}-${arch}.${ext}",
      "target": ["AppImage", "deb"]
    }
  },
  "dependencies": {
    "@tiptap/extension-highlight": "^3.22.4",
    "@tiptap/extension-placeholder": "^3.22.4",
    "@tiptap/extension-task-item": "^3.22.4",
    "@tiptap/extension-task-list": "^3.22.4",
    "@tiptap/extension-typography": "^3.22.4",
    "@tiptap/extension-underline": "^3.22.4",
    "@tiptap/pm": "^3.22.4",
    "@tiptap/starter-kit": "^3.22.4",
    "@tiptap/vue-3": "^3.22.4",
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^11.3.0",
    "marked": "^15.0.12",
    "pinia": "^3.0.4",
    "vue": "^3.4.21"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.6.0",
    "@vitejs/plugin-vue": "^5.0.4",
    "cross-env": "^7.0.3",
    "electron": "^29.4.6",
    "electron-builder": "^24.9.1",
    "typescript": "^5.2.2",
    "vite": "^5.2.0",
    "vite-plugin-electron": "^0.28.0",
    "vue-tsc": "^2.0.6"
  }
}
