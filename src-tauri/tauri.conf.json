{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-config-schema/schema.json",
  "productName": "Woo",
  "version": "0.5.3",
  "identifier": "com.nonegonotes.woo.tauri",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "lsof -i :5173 > /dev/null 2>&1 || npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Woo",
        "width": 1400,
        "height": 800,
        "minWidth": 680,
        "minHeight": 480,
        "center": true,
        "decorations": true,
        "resizable": true,
        "hiddenTitle": true,
        "titleBarStyle": "Overlay",
        "trafficLightPosition": { "x": 12, "y": 22 }
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; connect-src 'self' https://*.supabase.co https://generativelanguage.googleapis.com https://api.deepseek.com https://api.openai.com http://localhost:* ws://localhost:*; font-src 'self' data:;"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "fileAssociations": [
      {
        "ext": ["md", "markdown"],
        "name": "Markdown",
        "description": "Markdown 文档",
        "role": "Editor"
      },
      {
        "ext": ["txt"],
        "name": "纯文本",
        "description": "文本文件",
        "role": "Editor"
      }
    ]
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}
